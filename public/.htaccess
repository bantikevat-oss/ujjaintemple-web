# UjjainTemple.com — Hostinger origin config
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force www → root (or invert if you prefer www)
RewriteCond %{HTTP_HOST} ^www\.ujjaintemple\.com [NC]
RewriteRule ^(.*)$ https://ujjaintemple.com/$1 [L,R=301]

# ── Removed content → closest live page (SEO 301) ──
RewriteRule ^(en/|hi/)?puja-in-ujjain/mahakal-lok-corridor/?$ /mandirs/mahakal-lok/ [L,R=301]
RewriteRule ^(en/|hi/)?puja-in-ujjain/mahakaleshwar-bhasma-aarti-booking/?$ /mandirs/mahakaleshwar/ [L,R=301]
# Simhastha sub-pages consolidated into single landing (SEO focus on 'simhastha 2028')
RewriteRule ^(en/|hi/)?simhastha-2028/[^/]+/?$ /simhastha-2028/ [L,R=301]

# ── Locale migration (2026-07): English is now the default at root; Hindi moved to /hi/ ──
# Old English URLs (/en/...) permanently redirect to the new root-level English pages
RewriteRule ^en/(.*)$ /$1 [L,R=301]
RewriteRule ^en/?$ / [R=301,L]

# Trailing slash for directory-style URLs (matches SSG output)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !\.(html|css|js|woff2|webp|jpg|png|svg|xml|txt|json|webmanifest|pdf|ico|php)$
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ /$1/ [L,R=301]

# Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Brotli / gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# Block CSV leak
<Files "leads.csv">
  Order allow,deny
  Deny from all
</Files>
<Files "newsletter.csv">
  Order allow,deny
  Deny from all
</Files>

ErrorDocument 404 /404.html
